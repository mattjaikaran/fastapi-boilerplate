# =============================================================================
# APP
# =============================================================================
APP_NAME="FastAPI Postgres Boilerplate"
APP_ENV=development          # development | production | test
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1                # uvicorn workers (production: num CPUs * 2 + 1)
APP_LOG_LEVEL=debug          # debug | info | warning | error | critical
APP_VERSION=0.1.0

# =============================================================================
# SECURITY
# =============================================================================
SECRET_KEY=change-me-to-a-random-64-char-string-in-production
ALLOWED_HOSTS=["*"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_ECHO=false          # set true to log all SQL queries

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300          # seconds

# =============================================================================
# JWT
# =============================================================================
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# OTP
# =============================================================================
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

# =============================================================================
# CELERY
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false   # set true in tests to run tasks synchronously

# =============================================================================
# EMAIL (Resend)
# =============================================================================
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="noreply@yourdomain.com"
EMAIL_FROM_NAME="Your App"

# =============================================================================
# STORAGE (S3 / Cloudflare R2 / MinIO)
# =============================================================================
STORAGE_DRIVER=local         # local | s3
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=50
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket
AWS_S3_ENDPOINT_URL=        # optional — for R2/MinIO: https://your-account.r2.cloudflarestorage.com

# =============================================================================
# OBSERVABILITY
# =============================================================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=fastapi-app
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
PROMETHEUS_ENABLED=true

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute

# =============================================================================
# ADMIN
# =============================================================================
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=changeme

# =============================================================================
# AI / ML
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ML_MODEL_PATH=./models
ML_MAX_CONCURRENT_TASKS=4
